   },
   "source": "import numpy as np",
   "outputs": [],
   "execution_count": 4
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-06-23T08:37:52.952434Z",
     "start_time": "2026-06-23T08:37:52.942692Z"
    }
   },
   "cell_type": "code",
   "source": [
    "def relu(n):\n",
    "    return max(0, n)\n",
    "def weighted_sum(X):\n",
    "    w = [0.5, -0.4]\n",
    "    b = 1.0\n",
    "\n",
    "    return np.dot(X, w) + b\n"
   ],
   "id": "6890034f37195277",
   "outputs": [],
   "execution_count": 5
  },
  {
   "metadata": {},
   "cell_type": "markdown",
   "source": "# Task 1",
   "id": "d244aca9c4cb916d"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-06-23T08:38:36.888975Z",
     "start_time": "2026-06-23T08:38:36.874031Z"
    }
   },
   "cell_type": "code",
   "source": [
    "X = [2.0, 3.0]\n",
    "\n",
    "z = weighted_sum(X)\n",
    "print(f\"z = {round(z, 1)}\")\n",
    "\n",
    "print(f\"ReLU (z) = {round(relu(z), 1)}\")"
   ],
   "id": "4445c3029092dd86",
